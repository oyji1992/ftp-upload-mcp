{
  "name": "ftp-upload-mcp",
  "version": "1.0.0",
  "description": "Lightweight MCP server: upload local files via FTP and return permanent public HTTPS URLs",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "ftp-upload-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "README.zh-CN.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "mcp",
    "ftp",
    "upload",
    "https",
    "model-context-protocol"
  ],
  "author": "",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "basic-ftp": "^5.0.5",
    "zod": "^3.25.28"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
